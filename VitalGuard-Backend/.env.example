APP_NAME=VITALGUARD AI BACKEND
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false

MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=vitalguard

MODEL_PATH=classifier/fall_model.pkl
USE_MOCK_INFERENCE=true
USE_MOCK_STREAM=true
MOCK_ROOM_IDS=401,402,403,404

WINDOW_SIZE=20
STEP_SIZE=5
CHART_CACHE_SIZE=120
STALE_ROOM_SECONDS=20

CORS_ORIGINS=http://localhost:8081,http://localhost:19006
LOG_LEVEL=INFO
